{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.dev/schemas/common-rule.schema.json",
  "title": "Agentum Rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["level", "message"],
  "properties": {
    "level": {
      "type": "string",
      "enum": ["info", "warning", "error"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "when": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtimeIn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "runtimeNotIn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "profileIn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "profileNotIn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "modulesAll": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "modulesAny": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "modulesMissing": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
