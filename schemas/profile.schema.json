{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.dev/schemas/profile.schema.json",
  "title": "Agentum Profile Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "recommendedRuntime": {
      "type": "string",
      "minLength": 1
    },
    "defaultModules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "recommendedModules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "requiredPolicies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "https://agentum.dev/schemas/common-rule.schema.json"
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "prompt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "suggestModules": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
