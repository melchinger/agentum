{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.dev/schemas/runtime.schema.json",
  "title": "Agentum Runtime Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "language", "packageManagers", "directories", "requiredFiles", "commands"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "packageManagers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "directories": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "requiredFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+: .+"
      },
      "uniqueItems": true
    },
    "variables": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
      "uniqueItems": true
    },
    "detect": {
      "$ref": "https://agentum.dev/schemas/common-detect.schema.json"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "https://agentum.dev/schemas/common-rule.schema.json"
      }
    }
  }
}
