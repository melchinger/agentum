{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.dev/schemas/policy.schema.json",
  "title": "Agentum Policy Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "required": {
      "type": "boolean"
    },
    "files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+: .+"
      },
      "uniqueItems": true
    },
    "detect": {
      "$ref": "https://agentum.dev/schemas/common-detect.schema.json"
    }
  }
}
