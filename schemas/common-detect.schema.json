{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.dev/schemas/common-detect.schema.json",
  "title": "Agentum Detect Block",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
