{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.dev/schemas/module.schema.json",
  "title": "Agentum Module Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "category", "description", "compatibleRuntimes"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "compatibleRuntimes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "requiresModules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "conflictsWith": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "implies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "directories": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "requiredFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+: .+"
      },
      "uniqueItems": true
    },
    "env": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "detect": {
      "$ref": "https://agentum.dev/schemas/common-detect.schema.json"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "https://agentum.dev/schemas/common-rule.schema.json"
      }
    }
  }
}
