{
  "name": "nextjs",
  "description": "Next.js App Router skeleton with clear server/client boundaries.",
  "runtime": "Next.js App Router + TypeScript",
  "packageManagers": ["pnpm", "npm", "yarn"],
  "directories": [
    "src/app",
    "src/components",
    "src/lib",
    "tests"
  ],
  "requiredFiles": [
    "package.json",
    "tsconfig.json",
    "next.config.ts",
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/app/globals.css"
  ],
  "commands": [
    "install: {{PACKAGE_MANAGER}} install",
    "dev: {{PACKAGE_MANAGER}} run dev",
    "build: {{PACKAGE_MANAGER}} run build",
    "test: {{PACKAGE_MANAGER}} run test"
  ],
  "ciSetupCommand": "corepack enable",
  "ciTestCommand": "{{PACKAGE_MANAGER}} run test",
  "markers": {
    "files": ["package.json"],
    "packageJsonIndicators": ["next", "react"],
    "anyFiles": ["next.config.js", "next.config.ts"],
    "disallowFiles": ["composer.json", "pyproject.toml"]
  }
}
